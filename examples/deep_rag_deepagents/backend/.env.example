# LLM 配置
DEEP_RAG_MODEL=deepseek-chat
DEEP_RAG_API_KEY=your-api-key-here
DEEP_RAG_BASE_URL=https://api.deepseek.com/v1

# RAGFlow 配置
RAGFLOW_BASE_URL=http://localhost:9380
RAGFLOW_API_KEY=your-ragflow-key-here

# KB 类型名称子串（用于匹配数据集名称）
RAGFLOW_PRODUCT_KB=product
RAGFLOW_IMAGE_KB=image
RAGFLOW_FILE_KB=file
RAGFLOW_VIDEO_KB=video

# Agent 数据目录
AGENT_DATA_DIR=./agent_data
